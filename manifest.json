{
  "manifest_version": 3,
  "name": "CleanWeb Shield",
  "version": "1.0",
  "description": "실시간 악플 전송 차단 익스텐션",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}